{
  "name": "@proofvote/contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tealscript src/ProofVote.algo.ts artifacts",
    "build:no-algod": "tealscript --skip-algod src/ProofVote.algo.ts artifacts",
    "test": "jest --forceExit",
    "deploy": "ts-node deploy/deploy.ts",
    "lint": "eslint",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^7.0.0",
    "@algorandfoundation/tealscript": "^0.103.0",
    "algosdk": "^3.5.2",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.3",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "prettier": "^3.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "esModuleInterop": true,
            "resolveJsonModule": true
          }
        }
      ]
    },
    "testTimeout": 60000
  }
}

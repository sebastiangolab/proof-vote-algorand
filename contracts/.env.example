# Algorand deployer mnemonic (25 words, space-separated)
# This account needs TestNet ALGO for deployment fees
DEPLOYER_MNEMONIC=word1 word2 word3 ... word25

# Algod server URL (for TestNet, you can use a public node provider)
# Example: https://testnet-api.algonode.cloud or http://localhost:4001
# For local development, you might use http://localhost:4001 if running a local Algorand node
ALGOD_SERVER=https://testnet-api.algonode.cloud

# Algod port (default is 443 for HTTPS)
# If you're using a local node, it might be 4001 or 8080
ALGOD_PORT=443

# Algod API token (if required by your node provider)
# For public nodes you can leave this empty. For private/mainnet nodes it is
# typically a 64-character hex string, e.g.: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGOD_TOKEN=

# Network: testnet | mainnet | localnet
ALGORAND_NETWORK=testnet

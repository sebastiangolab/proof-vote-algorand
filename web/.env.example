# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

# Connection string to the MySQL database used by Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL=mysql://user:pass@host:3306/database

# ──────────────────────────────────────────────
# Algorand network
# ──────────────────────────────────────────────

# Which Algorand network to target: "mainnet" | "testnet" | "localnet"
# → See README.md "Algorand Networks" for when to use each option.
NEXT_PUBLIC_ALGORAND_NETWORK=testnet

# Algorand application (smart contract) ID — obtained after running `contracts/deploy`.
NEXT_PUBLIC_APP_ID=

# Algod node base URL (without trailing slash).
# https://mainnet-api.algonode.cloud - for mainnet
# https://testnet-api.algonode.cloud - for testnet
# http://localhost - for localnet (requires AlgoKit: `algokit localnet start`)
NEXT_PUBLIC_ALGOD_SERVER=https://testnet-api.algonode.cloud

# Algod node port (443 for HTTPS nodes, 4001 for AlgoKit localnet/sandbox).
NEXT_PUBLIC_ALGOD_PORT=443

# Algod API token — leave empty when using public AlgoNode endpoints.
# For localnet, use: aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
NEXT_PUBLIC_ALGOD_TOKEN=

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────

# Algorand wallet address of the platform owner (used for contract permission checks).
NEXT_PUBLIC_PLATFORM_OWNER_ADDRESS=
